# Postgres (container internal)
POSTGRES_DB=taskboard
POSTGRES_USER=taskboard
POSTGRES_PASSWORD=replace-with-strong-db-password

# JWT secrets (use long random strings, minimum 32+ chars)
JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret

BCRYPT_ROUNDS=12
SEED_DEFAULT_PASSWORD=replace-with-strong-shared-password
SEED_FORCE_PASSWORD_RESET=false
RUN_DB_SEED=false
